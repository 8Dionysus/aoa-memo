{
  "layer": "aoa-memo",
  "version": "0.2.3-draft",
  "status": "contract-hardening",
  "owns": [
    "memory objects",
    "provenance threads",
    "memory temperature posture",
    "salience posture",
    "recall contracts",
    "compact memory surfaces"
  ],
  "memory_object_kinds": [
    "anchor",
    "state_capsule",
    "episode",
    "claim",
    "decision",
    "pattern",
    "bridge",
    "audit_event"
  ],
  "supporting_objects": [
    "provenance_thread",
    "recall_contract"
  ],
  "recall_modes": [
    "working",
    "episodic",
    "semantic",
    "procedural",
    "lineage",
    "source_route"
  ],
  "temperature_scale": [
    "hot",
    "warm",
    "cool",
    "cold",
    "frozen"
  ],
  "core_docs": [
    "CHARTER.md",
    "docs/MEMORY_MODEL.md",
    "docs/MEMORY_OBJECT_PROFILES.md",
    "docs/MEMORY_TRUST_POSTURE.md",
    "docs/MEMORY_TEMPERATURES.md",
    "docs/LIFECYCLE.md",
    "docs/NARRATIVE_CORE_CONTRACT.md",
    "docs/FAILURE_LESSON_MEMORY.md",
    "docs/FAILURE_LESSON_RECALL.md",
    "docs/RECOVERY_PATTERN_MEMORY.md",
    "docs/RECOVERY_PATTERN_RECALL.md",
    "docs/WITNESS_TRACE_CONTRACT.md",
    "docs/WRITEBACK_TEMPERATURE_POLICY.md",
    "docs/QUEST_CHRONICLE_WRITEBACK.md",
    "docs/RUNTIME_WRITEBACK_SEAM.md",
    "docs/GROWTH_REFINERY_WRITEBACK.md",
    "docs/RECURRENCE_MEMORY_SUPPORT_SURFACES.md",
    "docs/MEMORY_READINESS_BOUNDARY.md",
    "docs/AGENT_MEMORY_POSTURE_SEAM.md",
    "docs/PLAYBOOK_MEMORY_SCOPES.md",
    "docs/KAG_TOS_BRIDGE_CONTRACT.md",
    "docs/KAG_SOURCE_EXPORT.md",
    "docs/MEMORY_EVAL_GUARDRAILS.md",
    "docs/OPERATIONAL_BOUNDARY.md",
    "docs/ROUTING_MEMORY_ADOPTION.md",
    "docs/BOUNDARIES.md",
    "ROADMAP.md"
  ],
  "schemas": [
    "schemas/memory_object.schema.json",
    "schemas/memory_object_profile.schema.json",
    "schemas/trust_posture.schema.json",
    "schemas/lifecycle_posture.schema.json",
    "schemas/anchor.schema.json",
    "schemas/state_capsule.schema.json",
    "schemas/episode.schema.json",
    "schemas/claim.schema.json",
    "schemas/decision.schema.json",
    "schemas/pattern.schema.json",
    "schemas/bridge.schema.json",
    "schemas/audit_event.schema.json",
    "schemas/failure_lesson_memory_v1.json",
    "schemas/recovery_pattern_memory_v1.json",
    "schemas/memory_object_surface_manifest.schema.json",
    "schemas/memory_object_catalog.schema.json",
    "schemas/memory_object_capsules.schema.json",
    "schemas/memory_object_sections.schema.json",
    "schemas/decay_policy.schema.json",
    "schemas/inquiry_checkpoint.schema.json",
    "schemas/checkpoint-to-memory-contract.schema.json",
    "schemas/provenance_thread.schema.json",
    "schemas/recall_contract.schema.json",
    "schemas/core-memory-contract.schema.json",
    "schemas/witness-trace.schema.json",
    "schemas/memory_chunk_face.schema.json",
    "schemas/memory_graph_face.schema.json",
    "schemas/memory_eval_guardrail_pack.schema.json"
  ],
  "generated_surface_families": [
    {
      "family": "doctrine",
      "source_of_truth": "aoa-memo-doctrine-route-surfaces-v1",
      "outputs": [
        "generated/memory_catalog.json",
        "generated/memory_catalog.min.json",
        "generated/memory_capsules.json",
        "generated/memory_sections.full.json"
      ],
      "validator_command": "python scripts/validate_memory_surfaces.py"
    },
    {
      "family": "memory_objects",
      "source_of_truth": "aoa-memo-object-example-surfaces-v1",
      "manifest": "examples/memory_object_surface_manifest.json",
      "outputs": [
        "generated/memory_object_catalog.json",
        "generated/memory_object_catalog.min.json",
        "generated/memory_object_capsules.json",
        "generated/memory_object_sections.full.json"
      ],
      "generator_command": "python scripts/generate_memory_object_surfaces.py",
      "validator_command": "python scripts/validate_memory_object_surfaces.py"
    },
    {
      "family": "kag_export",
      "source_of_truth": "aoa-memo-kag-source-export-v1",
      "outputs": [
        "generated/kag_export.min.json"
      ],
      "generator_command": "python scripts/generate_kag_export.py",
      "validator_command": "python scripts/validate_memo.py"
    }
  ],
  "validation_commands": [
    "python scripts/validate_memo.py",
    "python scripts/validate_memory_surfaces.py",
    "python scripts/validate_memory_object_surfaces.py",
    "python scripts/validate_lifecycle_audit_examples.py"
  ]
}
