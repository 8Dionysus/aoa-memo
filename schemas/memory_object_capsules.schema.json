{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/8Dionysus/aoa-memo/main/schemas/memory_object_capsules.schema.json",
  "title": "aoa-memo memory object capsules",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "capsule_version",
    "source_of_truth",
    "memory_objects"
  ],
  "properties": {
    "capsule_version": {
      "type": "integer",
      "const": 1
    },
    "source_of_truth": {
      "type": "string",
      "const": "aoa-memo-object-example-surfaces-v1"
    },
    "memory_objects": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "kind",
          "title",
          "summary",
          "recall_posture_short",
          "trust_posture_short",
          "use_when_short",
          "do_not_use_short",
          "strongest_next_source",
          "source_path"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "kind": {
            "type": "string",
            "enum": [
              "anchor",
              "state_capsule",
              "episode",
              "claim",
              "decision",
              "pattern",
              "bridge",
              "audit_event"
            ]
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "summary": {
            "type": "string",
            "minLength": 1
          },
          "recall_posture_short": {
            "type": "string",
            "minLength": 1
          },
          "trust_posture_short": {
            "type": "string",
            "minLength": 1
          },
          "use_when_short": {
            "type": "string",
            "minLength": 1
          },
          "do_not_use_short": {
            "type": "string",
            "minLength": 1
          },
          "strongest_next_source": {
            "type": "string",
            "minLength": 1
          },
          "source_path": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
