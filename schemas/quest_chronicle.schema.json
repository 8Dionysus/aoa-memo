{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://8dionysus.github.io/schemas/quest_chronicle_v1.schema.json",
  "title": "quest_chronicle_v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "title",
    "campaign_ref",
    "quest_refs",
    "agent_refs",
    "evidence_refs",
    "temperature",
    "summary",
    "stage_witness",
    "recall_anchor_ref",
    "captured_at",
    "public_safe"
  ],
  "properties": {
    "schema_version": {
      "const": "quest_chronicle_v1"
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 5
    },
    "campaign_ref": {
      "type": "string",
      "minLength": 1
    },
    "quest_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "agent_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "temperature": {
      "type": "string",
      "enum": [
        "hot",
        "warm",
        "cool",
        "cold",
        "frozen"
      ]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "stage_witness": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "stage_ref",
          "observation",
          "anchor_ref"
        ],
        "properties": {
          "stage_ref": {
            "type": "string",
            "minLength": 1
          },
          "observation": {
            "type": "string",
            "minLength": 1
          },
          "anchor_ref": {
            "type": "string",
            "minLength": 1
          },
          "next_recall_cue": {
            "type": "string"
          }
        }
      }
    },
    "recall_anchor_ref": {
      "type": "string",
      "minLength": 1
    },
    "captured_at": {
      "type": "string",
      "format": "date"
    },
    "notes": {
      "type": "string"
    },
    "public_safe": {
      "type": "boolean"
    }
  }
}
