{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aoa-memo/schemas/memo-registry.schema.json",
  "title": "AoA memo registry",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "layer", "objects"],
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "layer": {
      "type": "string",
      "const": "aoa-memo"
    },
    "objects": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "kind", "status", "summary"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 3
          },
          "kind": {
            "type": "string",
            "enum": ["episodic_memory", "semantic_memory", "provenance_thread", "recall_surface"]
          },
          "status": {
            "type": "string",
            "enum": ["active", "planned", "experimental", "deprecated"]
          },
          "summary": {
            "type": "string",
            "minLength": 10
          }
        }
      }
    }
  }
}
