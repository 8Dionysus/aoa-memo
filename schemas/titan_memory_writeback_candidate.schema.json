{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Titan Memory Writeback Candidate",
  "type": "object",
  "required": [
    "candidate_id",
    "source_records",
    "reason",
    "operator_approval"
  ],
  "properties": {
    "candidate_id": {
      "type": "string"
    },
    "source_records": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "reason": {
      "type": "string"
    },
    "owner_surface": {
      "type": "string"
    },
    "retention_risk": {
      "type": "string"
    },
    "operator_approval": {
      "type": "string",
      "enum": [
        "pending",
        "approved",
        "rejected"
      ]
    }
  }
}
