{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Titan Memory Digest",
  "type": "object",
  "required": [
    "digest_id",
    "record_count",
    "authority",
    "warning"
  ],
  "properties": {
    "digest_id": {
      "type": "string"
    },
    "record_count": {
      "type": "integer"
    },
    "authority": {
      "type": "string"
    },
    "warning": {
      "type": "string"
    },
    "recent_records": {
      "type": "array"
    }
  }
}
