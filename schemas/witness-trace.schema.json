{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aoa-memo/schemas/witness-trace.schema.json",
  "title": "Witness trace contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "trace_id",
    "run_ref",
    "goal",
    "status",
    "started_at",
    "steps",
    "summary_output"
  ],
  "properties": {
    "trace_id": {
      "type": "string",
      "minLength": 1
    },
    "run_ref": {
      "type": "string",
      "minLength": 1
    },
    "goal": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["planned", "running", "succeeded", "failed", "aborted", "needs_review"]
    },
    "started_at": {
      "type": "string",
      "format": "date-time"
    },
    "finished_at": {
      "type": "string",
      "format": "date-time"
    },
    "policy_flags": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "index",
          "kind",
          "intent"
        ],
        "properties": {
          "index": {
            "type": "integer",
            "minimum": 0
          },
          "kind": {
            "type": "string",
            "enum": ["observe", "tool", "decide", "write", "handoff", "error"]
          },
          "intent": {
            "type": "string",
            "minLength": 1
          },
          "tool_name": {
            "type": "string",
            "minLength": 1
          },
          "tool_input_redacted": {
            "type": "boolean"
          },
          "observation": {
            "type": "string",
            "minLength": 1
          },
          "state_delta": {
            "type": "string",
            "minLength": 1
          },
          "review_flag": {
            "type": "boolean"
          },
          "error_message": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "summary_output": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "format",
        "summary"
      ],
      "properties": {
        "format": {
          "type": "string",
          "const": "markdown"
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "human_checks": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        }
      }
    },
    "source_refs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "kind",
          "ref"
        ],
        "properties": {
          "kind": {
            "type": "string",
            "enum": ["playbook", "eval", "memory", "tos", "manual"]
          },
          "ref": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
