{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/8Dionysus/aoa-memo/main/schemas/memory_object.schema.json",
  "title": "aoa-memo memory object",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "id",
    "kind",
    "title",
    "summary",
    "scope",
    "time",
    "provenance",
    "trust",
    "lifecycle"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "kind": {
      "type": "string",
      "enum": [
        "anchor",
        "state_capsule",
        "episode",
        "claim",
        "decision",
        "pattern",
        "bridge",
        "audit_event"
      ]
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "scope": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "owner_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "payload_ref": {
      "type": "string"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "time": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "created_at"
      ],
      "properties": {
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "observed_at": {
          "type": "string",
          "format": "date-time"
        },
        "valid_from": {
          "type": "string",
          "format": "date-time"
        },
        "valid_to": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_refs"
      ],
      "properties": {
        "source_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "episode_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "provenance_thread_id": {
          "type": "string"
        }
      }
    },
    "trust": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "temperature"
      ],
      "properties": {
        "temperature": {
          "type": "string",
          "enum": [
            "hot",
            "warm",
            "cool",
            "cold",
            "frozen"
          ]
        },
        "confidence": {
          "oneOf": [
            {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            {
              "type": "string",
              "minLength": 1
            }
          ]
        },
        "authority": {
          "type": "string",
          "minLength": 1
        },
        "freshness": {
          "oneOf": [
            {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            {
              "type": "string",
              "minLength": 1
            }
          ]
        },
        "salience": {
          "oneOf": [
            {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            {
              "type": "string",
              "minLength": 1
            }
          ]
        },
        "salience_components": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "novelty": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "impact": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "recurrence": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "risk": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            }
          }
        }
      }
    },
    "lifecycle": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "review_state"
      ],
      "properties": {
        "review_state": {
          "type": "string",
          "enum": [
            "captured",
            "proposed",
            "confirmed",
            "frozen",
            "superseded",
            "retracted",
            "archived"
          ]
        },
        "supersedes": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "superseded_by": {
          "type": [
            "string",
            "null"
          ]
        },
        "review_after": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "retention_class": {
          "type": "string"
        },
        "promotion_state": {
          "type": "string",
          "enum": [
            "none",
            "candidate",
            "promoted",
            "demoted",
            "retired",
            "rescued"
          ]
        },
        "decay_policy_ref": {
          "type": "string"
        }
      }
    },
    "access": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "access_class": {
          "type": "string"
        },
        "read_scopes": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "write_scopes": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "promotion_scopes": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        }
      }
    },
    "bridges": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "tos_refs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "skill_refs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "eval_refs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "kag_lift_status": {
          "type": "string",
          "enum": [
            "none",
            "candidate",
            "lifted",
            "blocked"
          ]
        },
        "route_capsule_ref": {
          "type": "string"
        }
      }
    },
    "decay": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "ttl_days": {
          "type": "integer",
          "minimum": 0
        },
        "half_life_days": {
          "type": "integer",
          "minimum": 0
        },
        "demotion_target": {
          "type": "string",
          "enum": [
            "hot",
            "warm",
            "cool",
            "cold",
            "retired"
          ]
        },
        "retire_after": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "manual_veto": {
          "type": "boolean"
        }
      }
    },
    "promotion": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "trigger": {
          "type": "string"
        },
        "promoted_from": {
          "type": "string",
          "enum": [
            "hot",
            "warm",
            "cool",
            "cold"
          ]
        },
        "promoted_to": {
          "type": "string",
          "enum": [
            "warm",
            "cool",
            "cold",
            "frozen"
          ]
        },
        "promoted_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "review_after": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        }
      }
    }
  }
}
