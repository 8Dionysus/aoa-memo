{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/8Dionysus/aoa-memo/main/schemas/bridge.schema.json",
  "title": "aoa-memo bridge memory object",
  "allOf": [
    {
      "$ref": "https://raw.githubusercontent.com/8Dionysus/aoa-memo/main/schemas/memory_object.schema.json"
    },
    {
      "type": "object",
      "required": [
        "payload_ref",
        "access",
        "bridges"
      ],
      "properties": {
        "kind": {
          "const": "bridge"
        },
        "trust": {
          "type": "object",
          "required": [
            "temperature"
          ],
          "properties": {
            "temperature": {
              "enum": [
                "warm",
                "cool",
                "cold",
                "frozen"
              ]
            }
          }
        },
        "lifecycle": {
          "type": "object",
          "required": [
            "review_state",
            "retention_class"
          ],
          "properties": {
            "review_state": {
              "enum": [
                "proposed",
                "confirmed",
                "frozen",
                "superseded",
                "archived"
              ]
            },
            "retention_class": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "access": {
          "type": "object",
          "required": [
            "access_class",
            "read_scopes"
          ]
        },
        "bridges": {
          "type": "object",
          "required": [
            "kag_lift_status",
            "shared_envelope_ref"
          ],
          "properties": {
            "route_capsule_ref": {
              "type": "string",
              "minLength": 1
            },
            "shared_envelope_ref": {
              "type": "string",
              "minLength": 1
            }
          },
          "anyOf": [
            {
              "required": [
                "route_capsule_ref"
              ]
            },
            {
              "required": [
                "tos_refs"
              ],
              "properties": {
                "tos_refs": {
                  "type": "array",
                  "minItems": 1
                }
              }
            },
            {
              "required": [
                "skill_refs"
              ],
              "properties": {
                "skill_refs": {
                  "type": "array",
                  "minItems": 1
                }
              }
            },
            {
              "required": [
                "eval_refs"
              ],
              "properties": {
                "eval_refs": {
                  "type": "array",
                  "minItems": 1
                }
              }
            }
          ]
        }
      }
    }
  ]
}
