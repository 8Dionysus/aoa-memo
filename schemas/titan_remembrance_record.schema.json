{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aoa.local/schemas/titan_remembrance_record.schema.json",
  "title": "Titan Remembrance Record",
  "description": "Titan remembrance records preserve memory candidates with explicit provenance. Memory remains a route to source, not proof.",
  "oneOf": [
    {
      "title": "Legacy Titan remembrance memory",
      "type": "object",
      "required": [
        "record_id",
        "titan_name",
        "bearer_id",
        "role_key",
        "memory_kind",
        "source_ref",
        "summary"
      ],
      "properties": {
        "record_id": {
          "type": "string"
        },
        "titan_name": {
          "type": "string"
        },
        "bearer_id": {
          "type": "string"
        },
        "role_key": {
          "type": "string"
        },
        "incarnation_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "memory_kind": {
          "type": "string",
          "enum": [
            "role",
            "bearer",
            "session",
            "lesson",
            "fall",
            "succession",
            "remembrance"
          ]
        },
        "source_ref": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "redaction_state": {
          "type": "string",
          "enum": [
            "clear",
            "masked",
            "tombstoned"
          ]
        }
      },
      "additionalProperties": false
    },
    {
      "title": "Source-ref Titan remembrance candidate",
      "type": "object",
      "required": [
        "record_id",
        "bearer_id",
        "titan_name",
        "claim",
        "authority"
      ],
      "properties": {
        "record_id": {
          "type": "string",
          "minLength": 1
        },
        "bearer_id": {
          "type": "string",
          "pattern": "^titan:"
        },
        "titan_name": {
          "type": "string",
          "enum": [
            "Atlas",
            "Sentinel",
            "Mneme",
            "Forge",
            "Delta"
          ]
        },
        "claim": {
          "type": "string",
          "minLength": 1
        },
        "authority": {
          "type": "string",
          "enum": [
            "candidate",
            "route_to_source"
          ]
        },
        "source_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "receipt_id": {
          "type": "string",
          "minLength": 1
        },
        "session_id": {
          "type": "string",
          "minLength": 1
        },
        "lineage_event_ref": {
          "type": "string",
          "minLength": 1
        }
      },
      "anyOf": [
        {
          "required": [
            "source_refs"
          ]
        },
        {
          "required": [
            "receipt_id"
          ]
        },
        {
          "required": [
            "session_id"
          ]
        },
        {
          "required": [
            "lineage_event_ref"
          ]
        }
      ],
      "additionalProperties": false
    }
  ]
}
