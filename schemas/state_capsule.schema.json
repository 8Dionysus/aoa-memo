{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/8Dionysus/aoa-memo/main/schemas/state_capsule.schema.json",
  "title": "aoa-memo state capsule memory object",
  "allOf": [
    {
      "$ref": "https://raw.githubusercontent.com/8Dionysus/aoa-memo/main/schemas/memory_object.schema.json"
    },
    {
      "type": "object",
      "required": [
        "payload_ref",
        "access",
        "bridges"
      ],
      "properties": {
        "kind": {
          "const": "state_capsule"
        },
        "time": {
          "type": "object",
          "required": [
            "created_at",
            "observed_at"
          ]
        },
        "trust": {
          "type": "object",
          "required": [
            "temperature"
          ],
          "properties": {
            "temperature": {
              "enum": [
                "hot",
                "warm"
              ]
            }
          }
        },
        "lifecycle": {
          "type": "object",
          "required": [
            "review_state",
            "retention_class"
          ],
          "properties": {
            "review_state": {
              "enum": [
                "captured",
                "proposed",
                "confirmed"
              ]
            },
            "retention_class": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "access": {
          "type": "object",
          "required": [
            "access_class",
            "read_scopes",
            "write_scopes"
          ]
        },
        "bridges": {
          "type": "object",
          "required": [
            "route_capsule_ref"
          ],
          "properties": {
            "route_capsule_ref": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    }
  ]
}
